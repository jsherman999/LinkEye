{
  "name": "linkeye",
  "version": "0.1.0",
  "description": "Local web, API, and CLI app for archiving public LinkedIn profile snapshots and comparing changes.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "cli": "node src/cli.js",
    "monitor": "node src/cli.js monitor",
    "launchd:install": "node src/launchd.js install",
    "launchd:uninstall": "node src/launchd.js uninstall",
    "test": "node --test"
  },
  "bin": {
    "linkeye": "src/cli.js"
  },
  "keywords": [
    "linkedin",
    "archive",
    "monitor",
    "diff"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  }
}
